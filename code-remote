#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Ús:
  code-remote <ssh_host> [remote_path]

Exemples:
  code-remote raspi4 repos/ElMeuProjecte
  code-remote raspi4 ~/repos/ElMeuProjecte
  code-remote user@server /opt/project
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 1 ]]; then
  usage >&2
  exit 1
fi

host="$1"
shift
# No paths given: default to remote $HOME.
[[ $# -eq 0 ]] && set -- "~"

# Resolve all paths on the remote host in a single SSH call (one path per line).
resolved="$(ssh -o BatchMode=yes "$host" 'bash -s --' "$@" <<'EOF' 2>/dev/null
set -euo pipefail

for p in "$@"; do
  case "$p" in
    ""|"~")  target="$HOME" ;;
    ~/*)     target="$HOME/${p#~/}" ;;
    /*)      target="$p" ;;
    *)       target="$HOME/$p" ;;
  esac

  if command -v realpath >/dev/null 2>&1; then
    realpath -m "$target"
  elif command -v readlink >/dev/null 2>&1; then
    readlink -m "$target"
  else
    case "$target" in
      //*) printf "%s\n" "/${target##/}" ;;
      *)   printf "%s\n" "$target" ;;
    esac
  fi
done
EOF
)"

if [[ -z "$resolved" ]]; then
  echo "Error: no s'ha pogut resoldre cap ruta remota en '$host'." >&2
  exit 2
fi

# One VS Code window per path.
while IFS= read -r path; do
  [[ -z "$path" ]] && continue
  code --remote "ssh-remote+$host" -n "$path"
done <<<"$resolved"
