#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Ús:
  code-remote <ssh_host> [remote_path]

Exemples:
  code-remote raspi4 repos/ElMeuProjecte
  code-remote raspi4 ~/repos/ElMeuProjecte
  code-remote user@server /opt/project
EOF
}

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

if [[ $# -lt 1 || $# -gt 2 ]]; then
  usage >&2
  exit 1
fi

host="$1"
input_path="${2:-~}"

# Resolve the path on the remote host, relative to $HOME when not absolute.
resolved_path="$({
  ssh -o BatchMode=yes "$host" 'bash -s --' "$input_path" <<'EOF'
set -euo pipefail

p="${1:-~}"

case "$p" in
  ""|"~")
    target="$HOME"
    ;;
  ~/*)
    target="$HOME/${p#~/}"
    ;;
  /*)
    target="$p"
    ;;
  *)
    target="$HOME/$p"
    ;;
esac

if command -v realpath >/dev/null 2>&1; then
  realpath -m "$target"
elif command -v readlink >/dev/null 2>&1; then
  readlink -m "$target"
else
  case "$target" in
    //*) printf "%s\n" "/${target##/}" ;;
    *) printf "%s\n" "$target" ;;
  esac
fi
EOF
} 2>/dev/null)"

if [[ -z "$resolved_path" ]]; then
  echo "Error: no s'ha pogut resoldre la ruta remota en '$host'." >&2
  exit 2
fi

exec code --remote "ssh-remote+$host" "$resolved_path"
